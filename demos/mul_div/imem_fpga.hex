80000537 // lui x10, 0x80000 (MMIO Base for LEDs/7-Seg)

// Case 1: 10 * 3 = 30 (0x1E)
00a00093 // addi x1, x0, 10
00300113 // addi x2, x0, 3
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 2: 5 * 7 = 35 (0x23)
00500093 // addi x1, x0, 5
00700113 // addi x2, x0, 7
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 3: 100 * 2 = 200 (0xC8)
06400093 // addi x1, x0, 100
00200113 // addi x2, x0, 2
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 4: -5 * 4 = -20 (0xFFFFFFEC)
ffb00093 // addi x1, x0, -5
00400113 // addi x2, x0, 4
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 5: 12 * 12 = 144 (0x90)
00c00093 // addi x1, x0, 12
00c00113 // addi x2, x0, 12
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 6: 30 / 3 = 10 (0xA)
01e00093 // addi x1, x0, 30
00300113 // addi x2, x0, 3
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 7: 100 / 10 = 10 (0xA)
06400093 // addi x1, x0, 100
00a00113 // addi x2, x0, 10
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 8: 25 / 4 = 6 (0x6)
01900093 // addi x1, x0, 25
00400113 // addi x2, x0, 4
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 9: -20 / 5 = -4 (0xFFFFFFFC)
fec00093 // addi x1, x0, -20
00500113 // addi x2, x0, 5
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 10: 25 % 4 = 1 (0x1)
01900093 // addi x1, x0, 25
00400113 // addi x2, x0, 4
0220e1b3 // rem x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 11: 123 * 456 = 56088 (0xDAE8)
07b00093 // addi x1, x0, 123
1c800113 // addi x2, x0, 456
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 12: 56088 / 123 = 456 (0x1C8)
db800093 // li x1, 56088 (Partial representation)
07b00113 // addi x2, x0, 123
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 13: 1023 * 2 = 2046 (0x7FE)
3ff00093 // addi x1, x0, 1023
00200113 // addi x2, x0, 2
022081b3 // mul x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 14: 1000 / 3 = 333 (0x14D)
3e800093 // addi x1, x0, 1000
00300113 // addi x2, x0, 3
0220c1b3 // div x3, x1, x2
00352023 // sw x3, 0(x10)

// Case 15: 1000 % 3 = 1 (0x1)
3e800093 // addi x1, x0, 1000
00300113 // addi x2, x0, 3
0220e1b3 // rem x3, x1, x2
00352023 // sw x3, 0(x10)

// Infinite Loop
0000006f // j loop
