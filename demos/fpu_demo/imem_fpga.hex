// --- RISC-V FPU DEMO (Raw IEEE-754) ---
// Constants in DMEM (start at 0x000):
// 0x00: 3.5 (0x40600000)
// 0x04: 2.5 (0x40200000)
// 0x08: 1.5 (0x3FC00000)

80000537 // lui x10, 0x80000 (MMIO Base)
00000593 // li x11, 0       (DMEM Base)

// CASE 1: 3.5 + 2.5 = 6.0 (0x40C00000)
0005a083 // lw x1, 0(x11)   - Load 3.5
0045a103 // lw x2, 4(x11)   - Load 2.5
00000013 // nop
002081d3 // fadd.s x3, x1, x2 - x3 = 6.0 (Raw IEEE)
00000013 // nop
00352023 // sw x3, 0(x10)   - Store to MMIO

// CASE 2: 3.5 * 1.5 = 5.25 (0x40A80000)
0085a203 // lw x4, 8(x11)   - Load 1.5
00000013 // nop
104082d3 // fmul.s x5, x1, x4 - x5 = 5.25 (Raw IEEE)
00000013 // nop
00552023 // sw x5, 0(x10)   - Store to MMIO

// CASE 3: 3.5 / 2.5 = 1.4 (0x3FB33333)
18208353 // fdiv.s x6, x1, x2 - x6 = 1.4 (Raw IEEE)
00000013 // nop
00652023 // sw x6, 0(x10)   - Store to MMIO

0000006f // j halt
