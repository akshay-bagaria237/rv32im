// --- RISC-V CACHE DEMO: 50 ACCESSES MIXED PATTERN ---
// CACHE CONFIG: 4-Way Associative, 4 Sets.
// INDEX = Addr[3:2], TAG = Addr[31:4]
// SET 0: Addr 0x00, 0x10, 0x20, 0x30, 0x40 ...
// SET 1: Addr 0x04, 0x14, 0x24 ...
// SET 2: Addr 0x08, 0x18, 0x28 ...
// SET 3: Addr 0x0C, 0x1C, 0x2C ...

00000093 // addi x1, x0, 0 (Base Addr)

// --- PHASE 1: COMPULSORY MISSES (Total Access: 1-8) ---
0000a203 // 1. lw x4, 0(x1)   - SET 0, TAG 0 -> MISS (Compulsory)
00000013 // nop
0000a203 // 2. lw x4, 0(x1)   - SET 0, TAG 0 -> HIT
0040a203 // 3. lw x4, 4(x1)   - SET 1, TAG 0 -> MISS (Compulsory)
00000013 // nop
0040a203 // 4. lw x4, 4(x1)   - SET 1, TAG 0 -> HIT
0080a203 // 5. lw x4, 8(x1)   - SET 2, TAG 0 -> MISS (Compulsory)
00000013 // nop
0080a203 // 6. lw x4, 8(x1)   - SET 2, TAG 0 -> HIT
00c0a203 // 7. lw x4, 12(x1)  - SET 3, TAG 0 -> MISS (Compulsory)
00000013 // nop
00c0a203 // 8. lw x4, 12(x1)  - SET 3, TAG 0 -> HIT

// --- PHASE 2: CONFLICT STRESS ON SET 0 (Total Access: 9-18) ---
// Set 0 currently has TAG 0. Ways 1, 2, 3 are empty.
0100a203 // 9.  lw x4, 0x10(x1) - SET 0, TAG 1 -> MISS (Compulsory)
00000013 // nop
0200a203 // 10. lw x4, 0x20(x1) - SET 0, TAG 2 -> MISS (Compulsory)
00000013 // nop
0300a203 // 11. lw x4, 0x30(x1) - SET 0, TAG 3 -> MISS (Compulsory)
00000013 // nop
// Set 0 is now FULL (Tags 0, 1, 2, 3). Next access causes eviction.
0400a203 // 12. lw x4, 0x40(x1) - SET 0, TAG 4 -> MISS (Conflict! Kicks Tag 0)
00000013 // nop
0000a203 // 13. lw x4, 0x00(x1) - SET 0, TAG 0 -> MISS (Conflict! Kicks Tag 1)
00000013 // nop
0100a203 // 14. lw x4, 0x10(x1) - SET 0, TAG 1 -> MISS (Conflict! Kicks Tag 2)
00000013 // nop
0200a203 // 15. lw x4, 0x20(x1) - SET 0, TAG 2 -> MISS (Conflict! Kicks Tag 3)
00000013 // nop
0300a203 // 16. lw x4, 0x30(x1) - SET 0, TAG 3 -> MISS (Conflict! Kicks Tag 4)
00000013 // nop
0400a203 // 17. lw x4, 0x40(x1) - SET 0, TAG 4 -> MISS (Conflict! Kicks Tag 0)
00000013 // nop
0000a203 // 18. lw x4, 0x00(x1) - SET 0, TAG 0 -> MISS (Conflict)
00000013 // nop

// --- PHASE 3: LONG HIT STREAK (Total Access: 19-50) ---
// We use x8 as a loop counter to reach 50 total accesses.
01000413 // li x8, 16 (Loop 16 times * 2 accesses = 32 more)
// loop: (PC = 0x58)
0040a203 // Access (19 + 2n): lw x4, 4(x1) - SET 1, TAG 0 -> HIT (Still in cache)
0080a203 // Access (20 + 2n): lw x4, 8(x1) - SET 2, TAG 0 -> HIT (Still in cache)
fff40413 // addi x8, x8, -1
fa041ee3 // bne x8, x0, loop (Offset -36)

// --- HALT ---
ffffffff // SIGNAL: END
0000006f // j halt
